#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "$script_dir/.." && pwd)"

# codex/.codex is the version-controlled source of truth.
# ~/.codex is a writable runtime copy used by Codex.
mkdir -p "$repo_root/codex/.codex"
rsync -a \
  --exclude 'auth.json' \
  --exclude 'cache/' \
  --exclude 'logs/' \
  --exclude 'sessions/' \
  --exclude 'history*' \
  --exclude '*.tmp' \
  --exclude '*.lock' \
  "$HOME/.codex/" "$repo_root/codex/.codex/"

git -C "$repo_root" status --short -- codex/.codex
git -C "$repo_root" diff -- codex/.codex
